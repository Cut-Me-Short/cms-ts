# Publish only built output and required metadata

# Test files and artifacts
tests/
**/*.test.*
**/*.spec.*
**/__tests__/
*.test.ts
*.spec.ts

# Source files - only ship compiled dist/
src/
tsconfig.json
.github/
.gitignore

# Build artifacts and source maps
*.map
*.js.map
*.d.ts.map

# Development and CI/CD files
.npmrc
vitest.config.js
vitest.config.ts
.env
.env.local
.env.*.local
.git
.gitattributes
.editorconfig
.eslintrc*
.prettierrc*

# Optional: documentation (remove these if you want to include in npm package)
CHANGELOG.md
contributing.md
